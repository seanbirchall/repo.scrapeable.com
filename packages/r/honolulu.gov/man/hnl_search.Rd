\name{hnl_search}
\alias{hnl_search}
\title{Search the Honolulu Open Data catalog}
\usage{
hnl_search(query)
}
\arguments{
\item{query}{Search string matched against name and description (case-insensitive).}
}
\value{
A tibble of matching datasets.
}
\description{
Search across the catalog of Honolulu datasets by name and description.
}
